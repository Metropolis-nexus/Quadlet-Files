# Required Variables
NEXTAUTH_SECRET=REDACTED
NEXT_PRIVATE_ENCRYPTION_KEY=REDACTED
NEXT_PRIVATE_ENCRYPTION_SECONDARY_KEY=REDACTED
NEXT_PUBLIC_WEBAPP_URL=https://documenso.metropolis.nexus
NEXT_PRIVATE_DATABASE_URL=postgresql://documenso:REDACTED@documenso-postgres:5432/documenso

# Server Configuration
NEXT_PRIVATE_INTERNAL_WEBAPP_URL=http://localhost:3000

# Email Configuration
NEXT_PRIVATE_SMTP_TRANSPORT=smtp-auth
NEXT_PRIVATE_SMTP_HOST=mail.metropolis.nexus
NEXT_PRIVATE_SMTP_PORT=465
NEXT_PRIVATE_SMTP_USERNAME=documenso.system@metropolis.nexus
NEXT_PRIVATE_SMTP_PASSWORD=REDACTED
NEXT_PRIVATE_SMTP_SECURE=true
NEXT_PRIVATE_SMTP_FROM_ADDRESS=documenso.system@metropolis.nexus
NEXT_PRIVATE_SMTP_FROM_NAME=Documenso

# Storage Configuration
NEXT_PUBLIC_UPLOAD_TRANSPORT=database
NEXT_PUBLIC_DOCUMENT_SIZE_UPLOAD_LIMIT=100

# Signing Certificate Configuration
NEXT_PRIVATE_SIGNING_TRANSPORT=local
NEXT_PRIVATE_SIGNING_LOCAL_FILE_PATH=/certs/certificate.p12
NEXT_PRIVATE_SIGNING_PASSPHRASE=REDACTED

# Feature Flags
NEXT_PUBLIC_DISABLE_SIGNUP=false
NEXT_PUBLIC_FEATURE_BILLING_ENABLED=false

# Background Jobs
NEXT_PRIVATE_JOBS_PROVIDER=local

# Telemetry
DOCUMENSO_DISABLE_TELEMETRY=true