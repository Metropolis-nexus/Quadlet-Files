# Global settings
OC_BASE_DATA_PATH=/var/lib/opencloud
OC_CONFIG_DIR=/etc/opencloud
OC_DISABLE_VERSIONING=false
OC_EXCLUDE_RUN_SERVICES=idp,idm
OC_LOG_FILE=/logs/opencloud.log
OC_LOG_LEVEL=warn
## Pretty logs will cause the log file to not be written to
## https://doc.owncloud.com/ocis/7.2/deployment/general/general-info.html#globally-shared-logging-values
OC_LOG_PRETTY=false
OC_OIDC_CLIENT_ID=OpenCloud
OC_OIDC_CLIENT_SCOPES=openid profile email offline_access
OC_OIDC_ISSUER=https://auth.metropolis.nexus/application/o/opencloud/
OC_SHARING_PUBLIC_SHARE_MUST_HAVE_PASSWORD=false
OC_SHARING_PUBLIC_WRITEABLE_SHARE_MUST_HAVE_PASSWORD=true
## Environment variable from oCIS
OC_TRACING_ENABLED=false
OC_URL=https://opencloud.metropolis.nexus

# LDAP settings
FRONTEND_READONLY_USER_ATTRIBUTES="user.onPremisesSamAccountName,user.displayName,user.mail,user.passwordProfile,user.accountEnabled,user.appRoleAssignments"
OC_LDAP_BIND_DN=cn=OpenCloud,ou=users,dc=ldap,dc=goauthentik,dc=io
OC_LDAP_BIND_PASSWORD=REDACTED
OC_LDAP_DISABLED_USERS_GROUP_DN=cn=metropolis_banned,ou=groups,dc=ldap,dc=goauthentik,dc=io
OC_LDAP_DISABLE_USER_MECHANISM=none
OC_LDAP_GROUP_BASE_DN=ou=groups,dc=ldap,dc=goauthentik,dc=io
OC_LDAP_GROUP_FILTER=(cn=metropolis_vip)
OC_LDAP_GROUP_OBJECTCLASS=group
OC_LDAP_GROUP_SCHEMA_ID=uid
OC_LDAP_SERVER_WRITE_ENABLED=false
OC_LDAP_URI=ldap://192.168.0.111:389
OC_LDAP_USER_BASE_DN=ou=users,dc=ldap,dc=goauthentik,dc=io
OC_LDAP_USER_FILTER=(memberOf=cn=metropolis_vip,ou=groups,dc=ldap,dc=goauthentik,dc=io)
OC_LDAP_USER_OBJECTCLASS=user
## OpenCloud search only works based on Display Name
## so without setting it to the cn it will be impossible
## to search some users, and hard to search those 
## whose name do not match their username
OC_LDAP_USER_SCHEMA_DISPLAYNAME=cn
OC_LDAP_USER_SCHEMA_ID=uid
OC_LDAP_USER_SCHEMA_USERNAME=cn

# Proxy settings
PROXY_AUTOPROVISION_ACCOUNTS=false
PROXY_CSP_CONFIG_FILE_LOCATION=/etc/opencloud/csp.yaml
PROXY_ENABLE_BASIC_AUTH=false
PROXY_HTTP_ADDR=0.0.0.0:9200
PROXY_INSECURE_BACKENDS=true
PROXY_OIDC_ACCESS_TOKEN_VERIFY_METHOD=jwt
PROXY_OIDC_REWRITE_WELLKNOWN=true
PROXY_TLS=true
PROXY_TRANSPORT_TLS_CERT=/certs/fullchain.pem
PROXY_TRANSPORT_TLS_KEY=/certs/privkey.pem
PROXY_USER_CS3_CLAIM=username
PROXY_USER_OIDC_CLAIM=preferred_username

# Web client settings 
FRONTEND_CHECK_FOR_UPDATES=false
FRONTEND_DISABLE_RADICALE=true
WEB_OPTION_DISABLE_FEEDBACK_LINK=true

# TLS settings
# We disable TLS for internal service communication
# because they are all in the same container
OC_EVENTS_ENABLE_TLS=false
## Environment variable from oCIS
OC_GRPC_TLS_ENABLED=false
OC_HTTP_TLS_ENABLED=false
OC_INSECURE=false