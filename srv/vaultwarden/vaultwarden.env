# Database settings
DATABASE_URL=postgresql://vaultwarden:REDACTED@vaultwarden-postgres/vaultwarden

# WebSocket
WEBSOCKET_ENABLED=true

# Push notifications
PUSH_ENABLED=true
PUSH_INSTALLATION_ID=REDACTED
PUSH_INSTALLATION_KEY=REDACTED

# General settings
DOMAIN=https://vault.metropolis.nexus
SENDS_ALLOWED=true
TRASH_AUTO_DELETE_DAYS=30
DISABLE_ICON_DOWNLOAD=false
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=true
ORG_EVENTS_ENABLED=true
INVITATIONS_ALLOWED=false
INVITATION_ORG_NAME=Metropolis Vaultwarden
EMERGENCY_ACCESS_ALLOWED=true
EMAIL_CHANGE_ALLOWED=true
PASSWORD_HINTS_ALLOWED=true
## This should not be a security risk as SSO access is required
## and not all users will have their real email set
SHOW_PASSWORD_HINT=true

# Advanced settings
IP_HEADER=X-Real-IP
ICON_SERVICE=internal
HTTP_REQUEST_BLOCK_NON_GLOBAL_IPS=true
REQUIRE_DEVICE_EMAIL=true
ADMIN_TOKEN=REDACTED
DISABLE_ADMIN_TOKEN=false
ENFORCE_SINGLE_ORG_WITH_RESET_PW_POLICY=true

# SSO settings (OpenID Connect)
SSO_ENABLED=true
SSO_ONLY=true
SSO_SIGNUPS_MATCH_EMAIL=true
SSO_ALLOW_UNKNOWN_EMAIL_VERIFICATION=false
SSO_AUTHORITY=https://auth.metropolis.nexus/application/o/vaultwarden/
SSO_SCOPES=openid profile email offline_access
SSO_PKCE=true
SSO_CLIENT_ID=REDACTED
SSO_CLIENT_SECRET=REDACTED
SSO_DEBUG_TOKENS=false

# SMTP configuration
SMTP_HOST=mail.metropolis.nexus
SMTP_FROM=vaultwarden.system@metropolis.nexus
SMTP_FROM_NAME=Metropolis Vaultwarden
SMTP_USERNAME=vaultwarden.system@metropolis.nexus
SMTP_PASSWORD=REDACTED
SMTP_SECURITY=force_tls
SMTP_PORT=465
USE_SENDMAIL=false
SMTP_AUTH_MECHANISM=["Plain"]
SMTP_DEBUG=false
SMTP_ACCEPT_INVALID_CERTS=false
SMTP_ACCEPT_INVALID_HOSTNAMES=false

# Rocket settings
ROCKET_PORT=8443
ROCKET_TLS={certs="/certs/fullchain.pem",key="/certs/privkey.pem",prefer_server_cipher_order=true,ciphers=[ "TLS_ECDHE_ECDSA_WITH_AES_256_GCM_SHA384", "TLS_ECDHE_ECDSA_WITH_CHACHA20_POLY1305_SHA256", "TLS_ECDHE_ECDSA_WITH_AES_128_GCM_SHA256" ]}

# Undocumented settings
_ENABLE_YUBICO=false
_ENABLE_DUO=false
_ENABLE_EMAIL_2FA=false